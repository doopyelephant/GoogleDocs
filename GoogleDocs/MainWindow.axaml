
<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1920" d:DesignHeight="1080"
        x:Class="GoogleDocs.MainWindow"
        Title="GoogleDocs" WindowState="Maximized">
    <!-- <Window.KeyBindings>
        <KeyBinding Gesture=""></KeyBinding>
    </Window.KeyBindings> -->
    <Grid Name="MainGrid">
    <StackPanel Orientation="Vertical">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
            <Button Click="OpenDocButtonCallback" Width="250" Height="50" Margin="15" Name="OpenDocButton" Content="Open Document"></Button>
            <TextBox TextChanged="TextBox_OnTextChanged" Name="docidbox" Width="1000" Height="10"></TextBox>
        </StackPanel>
    <Button Click="OpenDebugMenu" Width="250" Height="50" Name="OpenDebugMenuButton" Content="Open Debug Menu" HorizontalAlignment="Left"></Button>
    <Button Click="FeelingLucky" Width="250" Height="50" Name="FeelingLuckyButton" Content="Open Most Recent" HorizontalAlignment="Left" Margin="15"></Button>

        <Panel Width="800" Height="40" Name="Toolbar">
            <Border Background="{DynamicResource SurfaceContainer}" CornerRadius="20">
                <StackPanel Orientation="Horizontal">
                    <Panel Width="30" Height="30" Margin="20,5,5,5" HorizontalAlignment="Center">
                        <Border Background="{DynamicResource Primary}" CornerRadius="4">
                            <TextBlock Text="B" HorizontalAlignment="Center" VerticalAlignment="Center"></TextBlock>
                        </Border>
                    </Panel>
                </StackPanel>
            </Border>
        </Panel>
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Height="800"
                      Width="1700">
            <Panel>
            <TextBlock Text="Loading..." Name="MainText"  TextWrapping="Wrap" ></TextBlock>
                <Rectangle Name="Cursor" Fill="Red" Width="2" Height="20" HorizontalAlignment="Left" VerticalAlignment="Top" />
            </Panel>
        </ScrollViewer>


    </StackPanel>
     <Popup x:Name="ManualCookiePopup"
           PlacementTarget="{Binding #MainGrid}"
           Placement="Center"
           IsLightDismissEnabled="True">
        <Border Background="{DynamicResource SurfaceContainer}" BorderThickness="1" CornerRadius="20" Padding="12">
                <StackPanel>
                    <TextBlock Text="No valid browser cookie paths found, please input your browser cookie path manually." Margin="0,0,0,10" HorizontalAlignment="Center"/>
                    <TextBox Name="CookiePathInput" Width="400" Margin="0,0,0,10"/>
                    <Button Content="Submit" HorizontalAlignment="Right" Click="SubmitCookiePath"/>
                </StackPanel>
        </Border>
    </Popup>
    <Popup x:Name="PickCookiePopup"
           PlacementTarget="{Binding #MainGrid}"
           Placement="Center"
            Width="500" Height="500">
        <Border Background="{DynamicResource SurfaceContainer}" BorderThickness="1" CornerRadius="20" Padding="12" HorizontalAlignment="Center">
                <StackPanel Name="BrowserList" Orientation="Vertical" HorizontalAlignment="Center">
                    <TextBlock Text="Multiple browsers were found, please select one." Margin="0,0,0,10"  HorizontalAlignment="Center"/>

                </StackPanel>
        </Border>
    </Popup>
        <Popup x:Name="PickPrompt"
               PlacementTarget="{Binding #MainGrid}"
               Placement="Center"
               Width="500" Height="500">
            <Border Background="{DynamicResource SurfaceContainer}" BorderThickness="1" CornerRadius="20" Padding="12" HorizontalAlignment="Center">
                <StackPanel Name="PromptList" Orientation="Vertical" HorizontalAlignment="Center">
                </StackPanel>
            </Border>
        </Popup>
    <Popup x:Name="DebugMenuPopup" Width="1000" Height="1000">
        <Border Background="{DynamicResource SurfaceContainer}" BorderThickness="1" CornerRadius="20" Padding="12">
            <StackPanel>
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Height="800">
                <TextBlock Name="DebugMenuTextBlock">
                </TextBlock>
            </ScrollViewer>
                <TextBox Name="DebugMenuInput"></TextBox>
                <Button Content="Submit" Click="SendDebugMenuText"></Button>
                <Button Content="Close" Click="CloseDebugMenu"></Button>
            </StackPanel>
        </Border>
    </Popup>
    </Grid>
</Window>
